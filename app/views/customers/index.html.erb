<% content_for :title, "取引先一覧 | freee" %>

<div class="space-y-5">
  <%# Flash notice %>
  <% if notice.present? %>
    <div class="flex items-center gap-3 rounded-lg border border-[#BBF7D0] bg-[#F0FDF4] px-4 py-3 text-sm text-[#166534]" id="notice">
      <svg class="h-4 w-4 flex-shrink-0 text-[#16A34A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
      <%= notice %>
    </div>
  <% end %>

  <%# Page Header %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-xl font-bold text-[#1F2937]">取引先</h1>
      <p class="mt-0.5 text-sm text-[#6B7280]">登録済み取引先の一覧・管理</p>
    </div>
    <%= link_to new_customer_path, class: "inline-flex items-center gap-2 rounded-md bg-[#3085D6] px-4 py-2 text-sm font-bold text-white shadow-sm hover:bg-[#2472C1] transition-colors" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
      </svg>
      取引先を追加
    <% end %>
  </div>

  <%# Stats Cards %>
  <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
    <div class="rounded-lg border border-[#E5E7EB] bg-white p-4 shadow-sm">
      <p class="text-xs font-medium text-[#6B7280]">登録数</p>
      <p class="mt-2 text-2xl font-bold text-[#1F2937]"><%= @customers.size %></p>
      <p class="mt-1 text-xs text-[#9CA3AF]">全取引先</p>
    </div>
    <div class="rounded-lg border border-[#E5E7EB] bg-white p-4 shadow-sm">
      <p class="text-xs font-medium text-[#6B7280]">アクティブ</p>
      <p class="mt-2 text-2xl font-bold text-[#059669]"><%= @customers.count { |c| c.customer_status == "active" } %></p>
      <p class="mt-1 text-xs text-[#9CA3AF]">有効な取引先</p>
    </div>
    <div class="rounded-lg border border-[#E5E7EB] bg-white p-4 shadow-sm">
      <p class="text-xs font-medium text-[#6B7280]">非アクティブ</p>
      <p class="mt-2 text-2xl font-bold text-[#9CA3AF]"><%= @customers.count { |c| c.customer_status != "active" } %></p>
      <p class="mt-1 text-xs text-[#9CA3AF]">停止中</p>
    </div>
    <div class="rounded-lg border border-[#E5E7EB] bg-white p-4 shadow-sm">
      <p class="text-xs font-medium text-[#6B7280]">電話あり</p>
      <p class="mt-2 text-2xl font-bold text-[#1F2937]"><%= @customers.count { |c| c.phone.present? } %></p>
      <p class="mt-1 text-xs text-[#9CA3AF]">連絡先登録済み</p>
    </div>
  </div>

  <%# Table %>
  <div class="overflow-hidden rounded-lg border border-[#E5E7EB] bg-white shadow-sm">
    <%# Table toolbar %>
    <div class="flex items-center justify-between border-b border-[#E5E7EB] px-5 py-3">
      <p class="text-sm font-medium text-[#374151]">
        取引先一覧
        <span class="ml-2 rounded-full bg-[#F3F4F6] px-2 py-0.5 text-xs font-bold text-[#6B7280]"><%= @customers.size %>件</span>
      </p>
    </div>

    <% if @customers.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead>
            <tr class="border-b border-[#E5E7EB] bg-[#F9FAFB]">
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-[#6B7280]">会社名</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-[#6B7280]">担当者</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-[#6B7280]">メールアドレス</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-[#6B7280]">電話番号</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-[#6B7280]">ステータス</th>
              <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wide text-[#6B7280]">操作</th>
            </tr>
          </thead>
          <tbody id="customers" class="divide-y divide-[#F3F4F6]">
            <% @customers.each do |customer| %>
              <tr class="group hover:bg-[#F9FAFB] transition-colors">
                <td class="whitespace-nowrap px-5 py-3.5">
                  <div class="flex items-center gap-3">
                    <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[#EFF6FF] text-xs font-bold text-[#3085D6]">
                      <%= customer.company_name.first rescue "?" %>
                    </div>
                    <span class="font-medium text-[#1F2937]"><%= customer.company_name %></span>
                  </div>
                </td>
                <td class="whitespace-nowrap px-4 py-3.5 text-[#374151]"><%= customer.contact_name %></td>
                <td class="whitespace-nowrap px-4 py-3.5 text-[#6B7280]"><%= customer.contact_email %></td>
                <td class="whitespace-nowrap px-4 py-3.5 text-[#6B7280]"><%= customer.phone.presence || "—" %></td>
                <td class="whitespace-nowrap px-4 py-3.5">
                  <% if customer.customer_status == "active" %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-[#D1FAE5] px-2.5 py-0.5 text-xs font-medium text-[#065F46]">
                      <span class="h-1.5 w-1.5 rounded-full bg-[#059669]"></span>
                      Active
                    </span>
                  <% else %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-[#F3F4F6] px-2.5 py-0.5 text-xs font-medium text-[#6B7280]">
                      <span class="h-1.5 w-1.5 rounded-full bg-[#9CA3AF]"></span>
                      <%= customer.customer_status %>
                    </span>
                  <% end %>
                </td>
                <td class="whitespace-nowrap px-5 py-3.5 text-right">
                  <div class="flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                    <%= link_to "詳細", customer, class: "rounded-md px-3 py-1.5 text-xs font-medium text-[#3085D6] hover:bg-[#EFF6FF] transition-colors" %>
                    <%= link_to "編集", edit_customer_path(customer), class: "rounded-md px-3 py-1.5 text-xs font-medium text-[#374151] hover:bg-[#F3F4F6] transition-colors" %>
                    <%= button_to "削除", customer, method: :delete, class: "cursor-pointer rounded-md px-3 py-1.5 text-xs font-medium text-[#EF4444] hover:bg-[#FEF2F2] transition-colors", data: { turbo_confirm: "この取引先を削除しますか？" } %>
                  </div>
                  <div class="flex items-center justify-end group-hover:hidden">
                    <%= link_to customer, class: "text-xs text-[#9CA3AF] hover:text-[#3085D6]" do %>
                      詳細を見る →
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="flex flex-col items-center justify-center px-6 py-20 text-center">
        <div class="flex h-14 w-14 items-center justify-center rounded-full bg-[#EFF6FF]">
          <svg class="h-7 w-7 text-[#3085D6]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h2 class="mt-4 text-sm font-bold text-[#1F2937]">取引先がまだ登録されていません</h2>
        <p class="mt-1 text-sm text-[#6B7280]">最初の取引先を追加して始めましょう。</p>
        <%= link_to "取引先を追加", new_customer_path, class: "mt-5 inline-flex items-center gap-2 rounded-md bg-[#3085D6] px-4 py-2 text-sm font-bold text-white shadow-sm hover:bg-[#2472C1]" %>
      </div>
    <% end %>
  </div>
</div>
