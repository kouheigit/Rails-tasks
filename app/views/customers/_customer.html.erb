<div id="<%= dom_id customer %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Company name:</strong>
    <%= customer.company_name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Contact name:</strong>
    <%= customer.contact_name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Contact email:</strong>
    <%= customer.contact_email %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Phone:</strong>
    <%= customer.phone %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Customer status:</strong>
    <%= customer.customer_status %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Memo:</strong>
    <%= customer.memo %>
  </div>
</div>
