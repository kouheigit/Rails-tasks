<% content_for :title, "取引先を追加 | freee" %>

<div class="mx-auto max-w-2xl space-y-5">
  <%# Breadcrumb %>
  <nav class="flex items-center gap-2 text-sm">
    <%= link_to "取引先", customers_path, class: "text-[#3085D6] hover:underline" %>
    <svg class="h-3.5 w-3.5 text-[#D1D5DB]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
    <span class="font-medium text-[#374151]">取引先を追加</span>
  </nav>

  <div class="rounded-lg border border-[#E5E7EB] bg-white shadow-sm">
    <div class="border-b border-[#E5E7EB] px-6 py-4">
      <h1 class="text-base font-bold text-[#1F2937]">新しい取引先を追加</h1>
      <p class="mt-0.5 text-sm text-[#6B7280]">取引先の基本情報を入力してください。</p>
    </div>
    <div class="p-6">
      <%= render "form", customer: @customer %>
    </div>
  </div>
</div>
