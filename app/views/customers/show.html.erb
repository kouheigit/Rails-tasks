<% content_for :title, "#{@customer.company_name} | freee" %>

<div class="space-y-5">
  <%# Flash notice %>
  <% if notice.present? %>
    <div class="flex items-center gap-3 rounded-lg border border-[#BBF7D0] bg-[#F0FDF4] px-4 py-3 text-sm text-[#166534]" id="notice">
      <svg class="h-4 w-4 flex-shrink-0 text-[#16A34A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
      <%= notice %>
    </div>
  <% end %>

  <%# Breadcrumb & Actions %>
  <div class="flex items-center justify-between">
    <nav class="flex items-center gap-2 text-sm">
      <%= link_to "取引先", customers_path, class: "text-[#3085D6] hover:underline" %>
      <svg class="h-3.5 w-3.5 text-[#D1D5DB]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
      <span class="font-medium text-[#374151]"><%= @customer.company_name %></span>
    </nav>
    <div class="flex items-center gap-2">
      <%= link_to "編集", edit_customer_path(@customer), class: "inline-flex items-center gap-1.5 rounded-md bg-[#3085D6] px-4 py-2 text-sm font-bold text-white shadow-sm hover:bg-[#2472C1] transition-colors" %>
      <%= button_to "削除", @customer, method: :delete, class: "inline-flex cursor-pointer items-center gap-1.5 rounded-md border border-[#FECACA] bg-white px-4 py-2 text-sm font-bold text-[#EF4444] shadow-sm hover:bg-[#FEF2F2] transition-colors", data: { turbo_confirm: "この取引先を削除しますか？" } %>
    </div>
  </div>

  <%# Header Card %>
  <div class="flex items-center gap-4 rounded-lg border border-[#E5E7EB] bg-white p-5 shadow-sm">
    <div class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-xl bg-[#EFF6FF] text-xl font-black text-[#3085D6]">
      <%= @customer.company_name.first rescue "?" %>
    </div>
    <div class="min-w-0">
      <h1 class="text-xl font-bold text-[#1F2937]"><%= @customer.company_name %></h1>
      <p class="mt-0.5 text-sm text-[#6B7280]"><%= @customer.contact_name %></p>
    </div>
    <div class="ml-auto">
      <% if @customer.customer_status == "active" %>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-[#D1FAE5] px-3 py-1 text-sm font-medium text-[#065F46]">
          <span class="h-2 w-2 rounded-full bg-[#059669]"></span>
          Active
        </span>
      <% else %>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-[#F3F4F6] px-3 py-1 text-sm font-medium text-[#6B7280]">
          <span class="h-2 w-2 rounded-full bg-[#9CA3AF]"></span>
          <%= @customer.customer_status %>
        </span>
      <% end %>
    </div>
  </div>

  <%# Detail Grid %>
  <div class="grid gap-5 lg:grid-cols-2">
    <%# Contact Info %>
    <div class="rounded-lg border border-[#E5E7EB] bg-white shadow-sm">
      <div class="border-b border-[#E5E7EB] px-5 py-3.5">
        <h2 class="text-sm font-semibold text-[#374151]">連絡先情報</h2>
      </div>
      <dl class="divide-y divide-[#F3F4F6]">
        <div class="flex items-center justify-between px-5 py-3.5">
          <dt class="text-sm text-[#6B7280]">担当者名</dt>
          <dd class="text-sm font-medium text-[#1F2937]"><%= @customer.contact_name.presence || "—" %></dd>
        </div>
        <div class="flex items-center justify-between px-5 py-3.5">
          <dt class="text-sm text-[#6B7280]">メールアドレス</dt>
          <dd class="text-sm font-medium text-[#1F2937]">
            <% if @customer.contact_email.present? %>
              <a href="mailto:<%= @customer.contact_email %>" class="text-[#3085D6] hover:underline"><%= @customer.contact_email %></a>
            <% else %>
              —
            <% end %>
          </dd>
        </div>
        <div class="flex items-center justify-between px-5 py-3.5">
          <dt class="text-sm text-[#6B7280]">電話番号</dt>
          <dd class="text-sm font-medium text-[#1F2937]"><%= @customer.phone.presence || "—" %></dd>
        </div>
      </dl>
    </div>

    <%# Status & Memo %>
    <div class="rounded-lg border border-[#E5E7EB] bg-white shadow-sm">
      <div class="border-b border-[#E5E7EB] px-5 py-3.5">
        <h2 class="text-sm font-semibold text-[#374151]">ステータス・メモ</h2>
      </div>
      <dl class="divide-y divide-[#F3F4F6]">
        <div class="flex items-center justify-between px-5 py-3.5">
          <dt class="text-sm text-[#6B7280]">ステータス</dt>
          <dd>
            <% if @customer.customer_status == "active" %>
              <span class="inline-flex items-center gap-1 rounded-full bg-[#D1FAE5] px-2.5 py-0.5 text-xs font-medium text-[#065F46]">
                <span class="h-1.5 w-1.5 rounded-full bg-[#059669]"></span>Active
              </span>
            <% else %>
              <span class="inline-flex items-center gap-1 rounded-full bg-[#F3F4F6] px-2.5 py-0.5 text-xs font-medium text-[#6B7280]">
                <span class="h-1.5 w-1.5 rounded-full bg-[#9CA3AF]"></span><%= @customer.customer_status %>
              </span>
            <% end %>
          </dd>
        </div>
        <div class="px-5 py-3.5">
          <dt class="text-sm text-[#6B7280]">メモ</dt>
          <dd class="mt-2 text-sm leading-relaxed text-[#374151]"><%= @customer.memo.presence || "メモはありません" %></dd>
        </div>
      </dl>
    </div>
  </div>
</div>
