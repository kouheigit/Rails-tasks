<% content_for :title, "#{@product.name}を編集 | Amazon管理" %>

<div class="bg-[#EAEDED] min-h-full">
  <%# Breadcrumb %>
  <div class="bg-white border-b border-[#DDD] px-6 py-2">
    <nav class="text-xs">
      <span class="text-[#0066C0] hover:text-[#C45500] cursor-pointer">ホーム</span>
      <span class="mx-1 text-[#555]">›</span>
      <%= link_to "商品管理", products_path, class: "text-[#0066C0] hover:text-[#C45500]" %>
      <span class="mx-1 text-[#555]">›</span>
      <%= link_to @product.name, product_path(@product), class: "text-[#0066C0] hover:text-[#C45500] truncate max-w-[200px] inline-block" %>
      <span class="mx-1 text-[#555]">›</span>
      <span class="text-[#555] font-medium">編集</span>
    </nav>
  </div>

  <div class="max-w-[860px] mx-auto px-4 py-6">
    <%# Page header with product info %>
    <div class="mb-5">
      <h1 class="text-2xl font-medium text-[#0F1111]">商品情報を編集</h1>
      <div class="flex items-center gap-3 mt-1.5">
        <span class="font-mono text-xs text-[#555] bg-[#F0F2F2] border border-[#D5D9D9] px-2 py-0.5 rounded">
          <%= @product.code %>
        </span>
        <span class="text-sm text-[#555]"><%= @product.name %></span>
        <% if @product.is_active? %>
          <span class="text-xs text-[#067D62] font-medium">● 販売中</span>
        <% else %>
          <span class="text-xs text-[#555] font-medium">● 販売停止</span>
        <% end %>
      </div>
    </div>

    <%# Warning banner for edit %>
    <div class="bg-[#FFF8E7] border border-[#F5C518] rounded p-4 mb-5 flex items-start gap-3">
      <svg class="h-5 w-5 text-[#F5A623] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <div class="text-xs text-[#555]">
        <strong class="text-[#0F1111]">編集の注意:</strong>
        商品コードを変更すると、既存の参照が無効になる可能性があります。価格・在庫の変更は即座に反映されます。
      </div>
    </div>

    <%= render "form", product: @product %>

    <div class="mt-4 flex items-center gap-4">
      <%= link_to "← 商品詳細に戻る", product_path(@product),
        class: "text-sm text-[#0066C0] hover:text-[#C45500] hover:underline" %>
      <span class="text-[#DDD]">|</span>
      <%= link_to "商品一覧に戻る", products_path,
        class: "text-sm text-[#0066C0] hover:text-[#C45500] hover:underline" %>
    </div>
  </div>
</div>
