<%= form_with(model: product) do |form| %>
  <% if product.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(product.errors.count, "error") %> prohibited this product from being saved:</h2>

      <ul>
        <% product.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :商品コード %>
    <%= form.text_field :code %>
  </div>

  <div>
    <%= form.label :商品名 %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :商品カテゴリー %>
    <%= form.collection_select :product_category_id, ProductCategory.order(:id), :id, :name %>
  </div>

  <div>
    <%= form.label :商品価格 %>
    <%= form.number_field :price %>
  </div>

  <div>
    <%= form.label :在庫 %>
    <%= form.number_field :stock %>
  </div>

  <div>
    <%= form.label :在庫アラート %>
    <%= form.number_field :alert_threshold %>
  </div>

  <div>
    <%= form.label :販売状態 %>
    <%= form.checkbox :is_active %>
  </div>

  <div>
    <%= form.label :商品説明 %>
    <%= form.textarea :description, rows: 4 %>
  </div>

  <div>
    <%= form.submit "新規作成する" %>
  </div>
<% end %>
