<% content_for :title, "Products" %>

<% if notice.present? %>
  <%= notice %>
<% end %>

<%= link_to "New product", new_product_path %>

<div>
  <%= form_with url: products_path, method: :get, local: true do %>
    <input type="text" name="title">

<label for="select">項目を選択したください:</label>
<select name="select">
  <option value="">--選択肢:--</option>
  <option value=1>全て</option>
  <option value=2>食品</option>
  <option value=3>日用品</option>
  <option value=4>電化製品</option>
  <option value=5>衣類</option>
  <option value=6>その他</option>
</select>

    <button type="submit">送信</button>
  <% end %>
</div>

<% if @products.any? %>
  <% @products.each do |product| %>
    <%= product.name %>
    <%= link_to "Show", product %>
    <%= link_to "Edit", edit_product_path(product) %>
    <%= button_to "Destroy", product, method: :delete, data: { turbo_confirm: "Are you sure?" } %>
  <% end %>

  <%= paginate @products %>
<% else %>
  No products found.
<% end %>
