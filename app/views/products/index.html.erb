<% content_for :title, "商品一覧 | Amazon管理" %>

<div class="bg-[#EAEDED] min-h-full">
  <%# Breadcrumb %>
  <div class="bg-white border-b border-[#DDD] px-6 py-2">
    <nav class="text-xs">
      <span class="text-[#0066C0] hover:text-[#C45500] cursor-pointer">ホーム</span>
      <span class="mx-1 text-[#555]">›</span>
      <span class="text-[#0066C0] hover:text-[#C45500] cursor-pointer">管理パネル</span>
      <span class="mx-1 text-[#555]">›</span>
      <span class="text-[#555] font-medium">商品管理</span>
    </nav>
  </div>

  <div class="max-w-[1400px] mx-auto px-4 py-4">
    <div class="flex gap-4">
      <%# Left Filter Sidebar %>
      <div class="w-[210px] flex-shrink-0">
        <div class="bg-white border border-[#DDD] rounded">
          <div class="px-4 py-3 border-b border-[#DDD]">
            <h3 class="text-sm font-bold text-[#0F1111]">カテゴリで絞り込む</h3>
          </div>
          <form method="GET" action="/products" class="p-4">
            <ul class="space-y-2">
              <li>
                <label class="flex items-center gap-2 text-sm cursor-pointer group">
                  <input type="radio" name="product_category_id" value=""
                    <%= "checked" if params[:product_category_id].blank? %>
                    class="accent-[#FF9900]">
                  <span class="text-[#0066C0] group-hover:text-[#C45500] group-hover:underline">
                    すべてのカテゴリ
                  </span>
                </label>
              </li>
              <% @categories.each do |category| %>
                <li>
                  <label class="flex items-center gap-2 text-sm cursor-pointer group">
                    <input type="radio" name="product_category_id" value="<%= category.id %>"
                      <%= "checked" if params[:product_category_id].to_s == category.id.to_s %>
                      class="accent-[#FF9900]">
                    <span class="text-[#0066C0] group-hover:text-[#C45500] group-hover:underline">
                      <%= category.name %>
                    </span>
                  </label>
                </li>
              <% end %>
            </ul>
            <button type="submit"
              class="mt-4 w-full bg-[#FF9900] hover:bg-[#FF8F00] active:bg-[#E47911] text-[#0F1111] text-sm font-bold py-2 px-3 rounded border border-[#A88734] shadow-sm cursor-pointer transition-colors">
              絞り込む
            </button>
          </form>
        </div>

        <%# Status filter %>
        <div class="bg-white border border-[#DDD] rounded mt-3">
          <div class="px-4 py-3 border-b border-[#DDD]">
            <h3 class="text-sm font-bold text-[#0F1111]">在庫状況</h3>
          </div>
          <div class="p-4 space-y-2">
            <label class="flex items-center gap-2 text-sm cursor-pointer group">
              <input type="checkbox" class="accent-[#FF9900]">
              <span class="text-[#0066C0] group-hover:text-[#C45500] group-hover:underline">在庫あり</span>
              <span class="ml-auto text-xs text-[#999]">(<%= @products.select(&:is_active?).count { |p| p.stock > p.alert_threshold } %>)</span>
            </label>
            <label class="flex items-center gap-2 text-sm cursor-pointer group">
              <input type="checkbox" class="accent-[#FF9900]">
              <span class="text-[#0066C0] group-hover:text-[#C45500] group-hover:underline">残りわずか</span>
              <span class="ml-auto text-xs text-[#CC0C39]">(<%= @products.count { |p| p.is_active? && p.stock <= p.alert_threshold } %>)</span>
            </label>
            <label class="flex items-center gap-2 text-sm cursor-pointer group">
              <input type="checkbox" class="accent-[#FF9900]">
              <span class="text-[#0066C0] group-hover:text-[#C45500] group-hover:underline">販売停止</span>
              <span class="ml-auto text-xs text-[#999]">(<%= @products.count { |p| !p.is_active? } %>)</span>
            </label>
          </div>
        </div>

        <%# Price range filter %>
        <div class="bg-white border border-[#DDD] rounded mt-3">
          <div class="px-4 py-3 border-b border-[#DDD]">
            <h3 class="text-sm font-bold text-[#0F1111]">価格帯</h3>
          </div>
          <div class="p-4">
            <div class="flex items-center gap-2">
              <input type="number" placeholder="最低" class="w-full border border-[#D5D9D9] rounded px-2 py-1 text-xs focus:outline-none focus:border-[#FF9900] focus:ring-1 focus:ring-[#FF9900]">
              <span class="text-xs text-[#555]">〜</span>
              <input type="number" placeholder="最高" class="w-full border border-[#D5D9D9] rounded px-2 py-1 text-xs focus:outline-none focus:border-[#FF9900] focus:ring-1 focus:ring-[#FF9900]">
            </div>
            <button class="mt-2 w-full text-xs text-[#0066C0] hover:text-[#C45500] hover:underline text-left">適用する</button>
          </div>
        </div>
      </div>

      <%# Main Content Area %>
      <div class="flex-1 min-w-0">
        <%# Results header %>
        <div class="bg-white border border-[#DDD] rounded px-4 py-3 mb-3">
          <div class="flex items-center justify-between mb-2">
            <div>
              <h1 class="text-lg font-bold text-[#0F1111]">商品一覧</h1>
              <p class="text-sm text-[#555]">
                <% if params[:product_category_id].present? %>
                  カテゴリ:
                  <span class="text-[#0066C0] font-medium">
                    <%= @categories.find { |c| c.id.to_s == params[:product_category_id].to_s }&.name %>
                  </span>
                  の検索結果 —
                <% end %>
                <span class="font-medium text-[#0F1111]"><%= @products.count %></span>
                <span>件中 1〜<%= [@products.count, 20].min %>件を表示</span>
              </p>
            </div>
            <%= link_to new_product_path,
              class: "inline-flex items-center gap-2 bg-[#FF9900] hover:bg-[#FF8F00] active:bg-[#E47911] text-[#0F1111] text-sm font-bold py-2 px-4 rounded border border-[#A88734] shadow-sm transition-colors" do %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
              </svg>
              新規商品登録
            <% end %>
          </div>
          <%# Sort bar %>
          <div class="flex items-center gap-3 pt-2 border-t border-[#F0F0F0]">
            <span class="text-xs text-[#555]">並び替え:</span>
            <a href="#" class="text-xs text-[#0066C0] hover:text-[#C45500] hover:underline font-medium">おすすめ順</a>
            <span class="text-[#DDD]">|</span>
            <a href="#" class="text-xs text-[#0066C0] hover:text-[#C45500] hover:underline">価格: 安い順</a>
            <span class="text-[#DDD]">|</span>
            <a href="#" class="text-xs text-[#0066C0] hover:text-[#C45500] hover:underline">価格: 高い順</a>
            <span class="text-[#DDD]">|</span>
            <a href="#" class="text-xs text-[#0066C0] hover:text-[#C45500] hover:underline">商品名順</a>
            <span class="text-[#DDD]">|</span>
            <a href="#" class="text-xs text-[#0066C0] hover:text-[#C45500] hover:underline">新着順</a>
          </div>
        </div>

        <%# Product Grid %>
        <% if @products.any? %>
          <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
            <% @products.each do |product| %>
              <div class="bg-white border border-[#DDD] rounded hover:shadow-lg transition-shadow flex flex-col <%= 'opacity-70' unless product.is_active? %>">
                <%# Product Image Area %>
                <div class="h-[160px] bg-[#F7F8F8] flex items-center justify-center border-b border-[#DDD] rounded-t relative">
                  <% if !product.is_active? %>
                    <div class="absolute top-2 left-2">
                      <span class="bg-[#555] text-white text-[10px] font-bold px-2 py-0.5 rounded">販売停止</span>
                    </div>
                  <% elsif product.stock <= product.alert_threshold %>
                    <div class="absolute top-2 left-2">
                      <span class="bg-[#CC0C39] text-white text-[10px] font-bold px-2 py-0.5 rounded">残りわずか</span>
                    </div>
                  <% else %>
                    <div class="absolute top-2 left-2">
                      <span class="bg-[#067D62] text-white text-[10px] font-bold px-2 py-0.5 rounded">在庫あり</span>
                    </div>
                  <% end %>
                  <div class="text-center p-4">
                    <svg class="h-14 w-14 text-[#CCCCCC] mx-auto mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                    </svg>
                    <span class="text-[10px] text-[#999] font-mono"><%= product.code %></span>
                  </div>
                </div>

                <%# Card Body %>
                <div class="p-3 flex flex-col flex-1">
                  <%# Category badge %>
                  <span class="inline-block bg-[#F0F2F2] text-[#555] text-[10px] px-1.5 py-0.5 rounded mb-1.5 w-fit">
                    <%= product.product_category.name %>
                  </span>

                  <%# Product Name %>
                  <h3 class="text-sm text-[#0F1111] leading-tight mb-2 line-clamp-2 flex-1">
                    <%= link_to product.name, product_path(product),
                      class: "hover:text-[#C45500] hover:underline" %>
                  </h3>

                  <%# Rating stars (decorative) %>
                  <div class="flex items-center gap-1 mb-1.5">
                    <div class="flex text-[#FF9900] text-xs">
                      <span>★★★★</span><span class="text-[#CCC]">★</span>
                    </div>
                    <span class="text-xs text-[#0066C0]">(在庫管理)</span>
                  </div>

                  <%# Price %>
                  <div class="mb-1">
                    <span class="text-[#CC0C39] text-lg font-bold">
                      ￥<%= number_with_delimiter(product.price) %>
                    </span>
                  </div>

                  <%# Stock info %>
                  <div class="text-xs text-[#555] mb-3">
                    在庫数:
                    <span class="font-medium <%= product.stock <= product.alert_threshold ? 'text-[#CC0C39]' : 'text-[#067D62]' %>">
                      <%= product.stock %>点
                    </span>
                    <span class="text-[#999]">/ アラート <%= product.alert_threshold %>点</span>
                  </div>

                  <%# Action Buttons %>
                  <div class="flex flex-col gap-1.5 mt-auto">
                    <%= link_to "詳細を見る", product_path(product),
                      class: "block text-center bg-[#FF9900] hover:bg-[#FF8F00] active:bg-[#E47911] text-[#0F1111] text-xs font-bold py-2 rounded border border-[#A88734] shadow-sm transition-colors" %>
                    <div class="flex gap-1">
                      <%= link_to "編集", edit_product_path(product),
                        class: "flex-1 text-center bg-white hover:bg-[#F7F8F8] text-[#0F1111] text-xs py-1.5 rounded border border-[#D5D9D9] shadow-sm transition-colors" %>
                      <%= button_to "削除", product, method: :delete,
                        data: { turbo_confirm: "「#{product.name}」を削除しますか？" },
                        class: "flex-1 text-center bg-white hover:bg-[#FFE7E5] text-[#CC0C39] text-xs py-1.5 rounded border border-[#D5D9D9] shadow-sm transition-colors cursor-pointer" %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="bg-white border border-[#DDD] rounded p-10 text-center">
            <svg class="h-16 w-16 text-[#CCC] mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
            <p class="text-[#555] text-sm mb-1">該当する商品が見つかりません</p>
            <p class="text-xs text-[#999]">検索条件を変更してお試しください</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
