<div id="<%= dom_id product %>">
  <div>
    <strong>商品コード:</strong>
    <%= product.code %>
  </div>
  <div>
    <strong>商品名:</strong>
    <%= product.name %>
  </div>
  <div>
    <strong>商品カテゴリー:</strong>
    <%= product.product_category.name %>
  </div>
  <div>
    <strong>商品価格:</strong>
    <%= product.price %>
  </div>
  <div>
    <strong>在庫:</strong>
    <%= product.stock %>
  </div>
  <div>
    <strong>在庫アラート:</strong>
    <%= product.alert_threshold %>
  </div>
  <div>
    <strong>販売状態:</strong>
    <%= product.is_active? ? "Yes" : "No" %>
  </div>
  <div>
    <strong>商品説明:</strong>
    <%= product.description %>
  </div>
</div>
