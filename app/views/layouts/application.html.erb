<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Amazon 商品管理" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Amazon管理">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#EAEDED] text-[#0F1111] antialiased">
    <div class="flex h-screen overflow-hidden">

      <%# ===== Left Sidebar ===== %>
      <aside class="flex w-[220px] flex-shrink-0 flex-col bg-[#131921]">
        <%# Amazon Logo %>
        <div class="flex h-14 items-center border-b border-white/10 px-4">
          <div class="flex items-center gap-1">
            <span class="text-[#FF9900] text-xl font-black tracking-tight">amazon</span>
            <span class="text-white text-[10px] font-bold mt-3">.co.jp</span>
          </div>
        </div>

        <%# Navigation %>
        <nav class="flex-1 overflow-y-auto py-2">
          <div class="px-4 py-2 bg-[#232F3E]">
            <p class="text-[11px] font-bold text-white">すべてのカテゴリ</p>
          </div>

          <ul class="space-y-0 mt-1">
            <li>
              <a href="#" class="flex items-center gap-3 px-4 py-2.5 text-sm text-[#CCCCCC] hover:bg-[#37475A] hover:text-white transition-colors border-b border-white/5">
                <svg class="h-4 w-4 flex-shrink-0 text-[#FF9900]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                ホーム
              </a>
            </li>
            <li>
              <%= link_to customers_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-[#CCCCCC] hover:bg-[#37475A] hover:text-white transition-colors border-b border-white/5" do %>
                <svg class="h-4 w-4 flex-shrink-0 text-[#FF9900]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                取引先管理
              <% end %>
            </li>
            <li>
              <%= link_to products_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-white bg-[#37475A] border-l-4 border-[#FF9900] font-bold border-b border-white/5" do %>
                <svg class="h-4 w-4 flex-shrink-0 text-[#FF9900]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                </svg>
                商品管理
              <% end %>
            </li>
            <li>
              <a href="#" class="flex items-center gap-3 px-4 py-2.5 text-sm text-[#CCCCCC] hover:bg-[#37475A] hover:text-white transition-colors border-b border-white/5">
                <svg class="h-4 w-4 flex-shrink-0 text-[#FF9900]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                注文管理
              </a>
            </li>
            <li>
              <a href="#" class="flex items-center gap-3 px-4 py-2.5 text-sm text-[#CCCCCC] hover:bg-[#37475A] hover:text-white transition-colors border-b border-white/5">
                <svg class="h-4 w-4 flex-shrink-0 text-[#FF9900]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
                レポート
              </a>
            </li>
            <li>
              <a href="#" class="flex items-center gap-3 px-4 py-2.5 text-sm text-[#CCCCCC] hover:bg-[#37475A] hover:text-white transition-colors border-b border-white/5">
                <svg class="h-4 w-4 flex-shrink-0 text-[#FF9900]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                設定
              </a>
            </li>
          </ul>
        </nav>

        <%# User area %>
        <div class="border-t border-white/10 p-4">
          <div class="flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-[#FF9900] text-xs font-bold text-[#0F1111]">管</div>
            <div class="min-w-0">
              <p class="truncate text-xs font-bold text-white">管理者</p>
              <p class="truncate text-[11px] text-[#9EA9BB]">Amazon Seller</p>
            </div>
          </div>
        </div>
      </aside>

      <%# ===== Main Content Area ===== %>
      <div class="flex flex-1 flex-col overflow-hidden">
        <%# Amazon Top Header %>
        <header class="flex-shrink-0 bg-[#131921]">
          <%# Main header row %>
          <div class="flex h-12 items-center gap-3 px-4">
            <%# Search bar %>
            <div class="flex flex-1 max-w-2xl">
              <select class="bg-[#F3F3F3] border-r border-[#CDCDCD] text-xs text-[#555] px-2 rounded-l focus:outline-none h-10 min-w-[70px]">
                <option>すべて</option>
                <option>商品</option>
                <option>取引先</option>
              </select>
              <input type="text" placeholder="商品・取引先を検索..." class="flex-1 h-10 px-3 text-sm text-[#0F1111] focus:outline-none">
              <button class="bg-[#FF9900] hover:bg-[#FF8F00] px-3 h-10 rounded-r border border-[#A88734]">
                <svg class="h-5 w-5 text-[#0F1111]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </button>
            </div>
            <%# Account & Cart %>
            <div class="flex items-center gap-4 ml-2">
              <button class="text-white hover:text-[#FF9900] transition-colors text-left">
                <div class="text-[10px] text-[#CCCCCC]">アカウント</div>
                <div class="text-xs font-bold">管理者 ▾</div>
              </button>
              <button class="text-white hover:text-[#FF9900] transition-colors flex items-center gap-1">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                </svg>
                <span class="text-xs font-bold">カート</span>
              </button>
            </div>
          </div>
          <%# Sub navigation bar %>
          <div class="bg-[#232F3E] flex items-center px-4 py-1.5 gap-5">
            <a href="#" class="text-xs text-white hover:text-[#FF9900] transition-colors whitespace-nowrap">本日のお得情報</a>
            <a href="#" class="text-xs text-white hover:text-[#FF9900] transition-colors whitespace-nowrap">新着商品</a>
            <a href="#" class="text-xs text-white hover:text-[#FF9900] transition-colors whitespace-nowrap">ランキング</a>
            <a href="#" class="text-xs text-white hover:text-[#FF9900] transition-colors whitespace-nowrap">在庫管理</a>
            <a href="#" class="text-xs text-white hover:text-[#FF9900] transition-colors whitespace-nowrap">カスタマーサービス</a>
          </div>
        </header>

        <%# Page Content %>
        <main class="flex-1 overflow-y-auto">
          <%= yield %>
        </main>
      </div>

    </div>
  </body>
</html>
