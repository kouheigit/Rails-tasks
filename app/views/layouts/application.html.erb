<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "freee 取引先" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="freee">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#EAEDED] text-[#0F1111] antialiased">
    <div class="flex h-screen overflow-hidden">

      <%# ===== Left Sidebar ===== %>
      <aside class="flex w-[220px] flex-shrink-0 flex-col bg-[#131921]">
        <%# Logo %>
        <div class="flex h-14 items-center border-b border-white/10 px-5">
          <div class="flex items-center gap-2">
            <span class="flex h-7 w-7 items-center justify-center rounded bg-[#3085D6] text-xs font-black text-white">f</span>
            <span class="text-sm font-bold text-white tracking-wide">freee</span>
          </div>
        </div>

        <%# Navigation %>
        <nav class="flex-1 overflow-y-auto py-4">
          <div class="px-3 mb-2">
            <p class="px-3 text-[10px] font-bold uppercase tracking-widest text-[#6B7A99]">メニュー</p>
          </div>

          <ul class="space-y-0.5 px-3">
            <li>
              <a href="#" class="flex items-center gap-3 rounded-md px-3 py-2.5 text-sm text-[#9EA9BB] hover:bg-white/10 hover:text-white transition-colors">
                <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                ホーム
              </a>
            </li>
            <li>
              <%= link_to customers_path, class: "flex items-center gap-3 rounded-md px-3 py-2.5 text-sm font-bold text-white bg-white/15" do %>
                <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                取引先
              <% end %>
            </li>
            <li>
              <a href="#" class="flex items-center gap-3 rounded-md px-3 py-2.5 text-sm text-[#9EA9BB] hover:bg-white/10 hover:text-white transition-colors">
                <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                請求書
              </a>
            </li>
            <li>
              <a href="#" class="flex items-center gap-3 rounded-md px-3 py-2.5 text-sm text-[#9EA9BB] hover:bg-white/10 hover:text-white transition-colors">
                <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                </svg>
                経費精算
              </a>
            </li>
            <li>
              <a href="#" class="flex items-center gap-3 rounded-md px-3 py-2.5 text-sm text-[#9EA9BB] hover:bg-white/10 hover:text-white transition-colors">
                <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
                レポート
              </a>
            </li>
          </ul>

          <div class="mt-6 px-3 mb-2">
            <p class="px-3 text-[10px] font-bold uppercase tracking-widest text-[#6B7A99]">設定</p>
          </div>
          <ul class="space-y-0.5 px-3">
            <li>
              <a href="#" class="flex items-center gap-3 rounded-md px-3 py-2.5 text-sm text-[#9EA9BB] hover:bg-white/10 hover:text-white transition-colors">
                <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                設定
              </a>
            </li>
          </ul>
        </nav>

        <%# User area %>
        <div class="border-t border-white/10 p-4">
          <div class="flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-[#3085D6] text-xs font-bold text-white">U</div>
            <div class="min-w-0">
              <p class="truncate text-xs font-bold text-white">ユーザー</p>
              <p class="truncate text-[11px] text-[#9EA9BB]">freee株式会社</p>
            </div>
          </div>
        </div>
      </aside>

      <%# ===== Main Content Area ===== %>
      <div class="flex flex-1 flex-col overflow-hidden">
        <%# Top Header %>
        <header class="flex h-14 flex-shrink-0 items-center justify-between border-b border-[#E5E7EB] bg-white px-6">
          <div class="flex items-center gap-2 text-sm text-[#6B7280]">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>取引先管理</span>
          </div>
          <div class="flex items-center gap-3">
            <button class="rounded-full p-2 text-[#6B7280] hover:bg-[#F3F4F6]">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
            </button>
            <button class="rounded-full p-2 text-[#6B7280] hover:bg-[#F3F4F6]">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </button>
          </div>
        </header>

        <%# Page Content %>
        <main class="flex-1 overflow-y-auto p-6">
          <%= yield %>
        </main>
      </div>

    </div>
  </body>
</html>
